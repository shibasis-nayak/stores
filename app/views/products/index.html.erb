<% if notice %>
  <p>
    <%= notice %>
  </p>
<% end %>

<div style="
  background-color: lightgray;
  padding: 20px;
  border-radius: 10px;
  margin-bottom: 20px;
">

  <h2>Filters</h2>

  <%= form_with url: products_path, method: :get, local: true do %>

    <div style="
      display: flex;
      gap: 20px;
      flex-wrap: wrap;
      align-items: end;
    ">

      <div>
        <label>Name</label><br>

        <%= text_field_tag :name,
              params[:name],
              placeholder: "Enter Product Name" %>
      </div>

      <div>
        <label>Price</label><br>

        <%= text_field_tag :price,
              params[:price],
              placeholder: "Enter Price" %>
      </div>

      <div>
        <label>Category</label><br>

        <%= select_tag :category_id,
              options_from_collection_for_select(
                @categories,
                :id,
                :name,
                params[:category_id]
              ),
              include_blank: "All Categories" %>
      </div>

      <div>
  <label>Stock Status</label><br>

  <%= select_tag :stock_status,
        options_for_select(
          [
            ["All", ""],
            ["In Stock", "in_stock"],
            ["Out of Stock", "out_of_stock"]
          ],
          params[:stock_status]
        ) %>
    </div>

      <div>
        <%= submit_tag "Search",
              style: "
                background-color: blue;
                color: white;
                padding: 10px 20px;
                border: none;
                border-radius: 5px;
                cursor: pointer;
              " %>
      </div>

      <div>
        <%= link_to "Clear",
              products_path,
              style: "
                background-color: gray;
                color: white;
                padding: 10px 20px;
                text-decoration: none;
                border-radius: 5px;
                display: inline-block;
              " %>
      </div>

    </div>

  <% end %>

</div>

<div style="
  text-align: center;
  background-color: lightgray;
  padding: 40px;
  border-radius: 10px;
">

  <h1 style="
    color: darkblue;
    font-size: 40px;
    margin-bottom: 20px;
  ">
    Products
  </h1>

  <%= link_to "New Product",
      "/products/new",
      style: "
        background-color: blue;
        color: white;
        padding: 12px 20px;
        text-decoration: none;
        border-radius: 8px;
        font-size: 18px;
      "
  %>

</div>

<br>

<% @products.each do |product| %>

  <div style="
    background-color: #f5f5f5;
    padding: 20px;
    margin-bottom: 20px;
    border-radius: 10px;
    border: 1px solid gray;
  ">

    <h2 style="
      color: darkblue;
      display: flex;
      justify-content: space-between;
      align-items: center;
    ">

      <%= product.name %>

      <% if product.stock > 5 %>

        <span class="badge bg-success">
          In Stock
        </span>

      <% elsif product.stock > 0 %>

        <span class="badge bg-warning text-dark">
          Only <%= product.stock %> left!
        </span>

      <% else %>

        <span class="badge bg-danger">
          Out of Stock
        </span>

      <% end %>

    </h2>

    <p>
      <strong>Price:</strong>
      <%= product.price %>
    </p>

    <p>
      <strong>Description:</strong>
      <%= product.description %>
    </p>

    <p>
      <strong>Category:</strong>
      <%= product&.category&.name %>
    </p>

    <%= link_to "Show",
        "/products/#{product.id}",
        style: "
          background-color: blue;
          color: white;
          padding: 8px 14px;
          text-decoration: none;
          border-radius: 5px;
          margin-right: 10px;
        "
    %>

    <%= link_to "Edit",
        "/products/#{product.id}/edit",
        style: "
          background-color: orange;
          color: white;
          padding: 8px 14px;
          text-decoration: none;
          border-radius: 5px;
          margin-right: 10px;
        "
    %>

    <%= link_to "Delete",
        "/products/#{product.id}",
        data: {
          turbo_method: :delete,
          turbo_confirm: "Are you sure?"
        },
        style: "
          background-color: red;
          color: white;
          padding: 8px 14px;
          text-decoration: none;
          border-radius: 5px;
        "
    %>

  </div>

<% end %>

<div class="d-flex justify-content-center mt-4">
  <%= paginate @products %>
</div>