<div class="container py-5">

  <div class="row justify-content-center">

    <div class="col-lg-8">

      <div class="card shadow-lg border-0 rounded-4">

        <div class="card-header bg-primary text-white text-center py-4">

          <h2 class="mb-0">
            📦 Add New Product
          </h2>

          <p class="mb-0 mt-2">
            Fill in the details below to create a new product.
          </p>

        </div>

        <div class="card-body p-5">

          <%= form_with model: @product do |form| %>

            <div class="mb-4">

              <%= form.label :name, class: "form-label fw-bold" %>

              <%= form.text_field :name,
                    class: "form-control form-control-lg",
                    placeholder: "Enter Product Name" %>

            </div>


            <div class="row">

              <div class="col-md-6 mb-4">

                <%= form.label :price, class: "form-label fw-bold" %>

                <%= form.number_field :price,
                      class: "form-control form-control-lg",
                      placeholder: "Enter Price" %>

              </div>

              <div class="col-md-6 mb-4">

                <%= form.label :stock, class: "form-label fw-bold" %>

                <%= form.number_field :stock,
                      class: "form-control form-control-lg",
                      min: 0,
                      placeholder: "Available Stock" %>

              </div>

            </div>


            <div class="mb-4">

              <%= form.label :description, class: "form-label fw-bold" %>

              <%= form.text_area :description,
                    rows: 4,
                    class: "form-control",
                    placeholder: "Write a short description about the product..." %>

            </div>


            <div class="mb-4">

              <%= form.label :category_id, "Category", class: "form-label fw-bold" %>

              <%= form.collection_select(
                    :category_id,
                    Category.all,
                    :id,
                    :name,
                    { prompt: "Select Category" },
                    { class: "form-select form-select-lg" }
                  ) %>

            </div>


            <div class="mb-4">

              <%= form.label :images,
                    "Product Images",
                    class: "form-label fw-bold" %>

              <%= form.file_field :images,
                    multiple: true,
                    class: "form-control form-control-lg" %>

              <div class="form-text">
                📷 You can upload one or multiple product images.
              </div>

            </div>


            <hr class="my-4">


            <div class="d-flex justify-content-between">

              <%= link_to "← Back",
                    products_path,
                    class: "btn btn-outline-secondary btn-lg" %>

              <%= form.submit "Create Product",
                    class: "btn btn-success btn-lg px-5" %>

            </div>

          <% end %>

        </div>

      </div>

    </div>

  </div>

</div>