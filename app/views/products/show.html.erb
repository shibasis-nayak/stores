<div class="container py-5">

  <div class="card border-0 shadow-lg rounded-4 overflow-hidden">

    <!-- Header -->
    <div class="p-5 text-white"
         style="background: linear-gradient(135deg,#4f46e5,#06b6d4);">

      <div class="d-flex justify-content-between align-items-center">

        <div>
          <h1 class="fw-bold mb-2">
            <%= @product.name %>
          </h1>

          <h5 class="text-light">
            <%= @product.category&.name %>
          </h5>
        </div>

        <% if @product.stock > 5 %>

          <span class="badge bg-success fs-5 px-4 py-3 rounded-pill">
            ✅ In Stock
          </span>

        <% elsif @product.stock > 0 %>

          <span class="badge bg-warning text-dark fs-5 px-4 py-3 rounded-pill">
            ⚠ Only <%= @product.stock %> Left
          </span>

        <% else %>

          <span class="badge bg-danger fs-5 px-4 py-3 rounded-pill">
            ❌ Out of Stock
          </span>

        <% end %>

      </div>

    </div>

    <div class="card-body p-5">

      <div class="row g-5">

        <!-- Product Image -->
        <div class="col-lg-6">

          <% if @product.images.attached? %>

            <%= image_tag @product.images.first,
                  class: "img-fluid rounded-4 shadow-lg border border-4 border-white",
                  style: "height:450px;width:100%;object-fit:cover;" %>

          <% else %>

            <div class="bg-light rounded-4 shadow d-flex justify-content-center align-items-center"
                 style="height:450px;">

              <h3 class="text-secondary">
                No Image Available
              </h3>

            </div>

          <% end %>

        </div>

        <!-- Details -->
        <div class="col-lg-6">

          <div class="card border-0 shadow rounded-4">

            <div class="card-header text-white"
                 style="background:linear-gradient(135deg,#f97316,#ef4444);">

              <h3 class="mb-0">
                📦 Product Details
              </h3>

            </div>

            <div class="card-body">

              <div class="mb-4">

                <h6 class="text-muted">
                  Price
                </h6>

                <h2 class="text-success fw-bold">
                  ₹ <%= @product.price %>
                </h2>

              </div>

              <div class="mb-4">

                <span class="badge bg-info fs-6 px-3 py-2">
                  🏷 <%= @product.category&.name %>
                </span>

              </div>

              <div class="mb-4">

                <span class="badge bg-dark fs-6 px-3 py-2">
                  📦 Stock : <%= @product.stock %>
                </span>

              </div>

              <hr>

              <h5 class="text-primary">
                📝 Description
              </h5>

              <p class="text-secondary">
                <%= @product.description %>
              </p>

              <hr>

              <h5 class="text-primary">
                ⭐ Average Rating
              </h5>

              <% average = @product.ratings.average(:rating).to_f %>

              <% if average > 0 %>

                <div class="display-6">

                  <% average.round.times do %>
                    ⭐
                  <% end %>

                  <span class="fs-4 text-dark">
                    <%= average.round(1) %>/5
                  </span>

                </div>

              <% else %>

                <span class="badge bg-secondary">
                  No Ratings Yet
                </span>

              <% end %>

            </div>

          </div>

        </div>

      </div>

      <!-- Gallery -->

      <% if @product.images.attached? %>

        <div class="mt-5">

          <div class="text-center mb-4">

            <h2 class="fw-bold text-primary">
              🖼 Product Gallery
            </h2>

          </div>

          <div class="row">

            <% @product.images.each do |image| %>

              <div class="col-lg-3 col-md-4 col-6 mb-4">

                <%= image_tag image,
                      class: "img-fluid rounded-4 shadow-lg border border-3 border-light",
                      style: "height:220px;width:100%;object-fit:cover;" %>

              </div>

            <% end %>

          </div>

        </div>

      <% end %>

      <!-- Rating -->

      <div class="card mt-5 border-0 shadow rounded-4">

        <div class="card-header text-white"
             style="background:linear-gradient(135deg,#e11d48,#ec4899);">

          <h4 class="mb-0">
            🌟 Rate This Product
          </h4>

        </div>

        <div class="card-body">

          <%= form_with model: @rating,
                url: product_ratings_path(@product),
                local: true do |form| %>

            <div class="row align-items-end">

              <div class="col-md-5">

                <%= form.label :rating,
                      class: "form-label fw-bold" %>

                <%= form.select :rating,
                      options_for_select(
                        [
                          ["⭐ 1 Star",1],
                          ["⭐⭐ 2 Stars",2],
                          ["⭐⭐⭐ 3 Stars",3],
                          ["⭐⭐⭐⭐ 4 Stars",4],
                          ["⭐⭐⭐⭐⭐ 5 Stars",5]
                        ],
                        @rating.rating
                      ),
                      {},
                      class: "form-select form-select-lg" %>

              </div>

              <div class="col-md-3">

                <%= form.submit "Submit Rating",
                      class: "btn btn-danger btn-lg w-100 shadow" %>

              </div>

            </div>

          <% end %>

        </div>

      </div>

      <!-- Buttons -->

      <div class="text-center mt-5">

        <%= link_to "⬅ Back",
              products_path,
              class: "btn btn-secondary btn-lg px-5 me-3 rounded-pill shadow" %>

        <%= link_to "✏ Edit Product",
              edit_product_path(@product),
              class: "btn btn-primary btn-lg px-5 rounded-pill shadow" %>

      </div>

    </div>

  </div>

</div>