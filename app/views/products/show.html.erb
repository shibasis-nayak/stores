<div class="container mt-4">

  <h1 class="text-primary mb-4 d-flex justify-content-between align-items-center">

    <%= @product.name %>

    <% if @product.stock > 5 %>

      <span class="badge bg-success">
        In Stock
      </span>

    <% elsif @product.stock > 0 %>

      <span class="badge bg-warning text-dark">
        Only <%= @product.stock %> left!
      </span>

    <% else %>

      <span class="badge bg-danger">
        Out of Stock
      </span>

    <% end %>

  </h1>

  <div class="card">

    <div class="card-body">

      <p class="fs-5">
        <strong>Price:</strong>
        <%= @product.price %>
      </p>

      <p class="fs-5">
        <strong>Description:</strong>
        <%= @product.description %>
      </p>

      <p class="fs-5">
        <strong>Category:</strong>
        <%= @product&.category&.name %>
      </p>

      <hr>

      <h4 class="mb-3">
        Product Images
      </h4>

      <% if @product.images.attached? %>

        <div class="row">

          <% @product.images.each do |image| %>

            <div class="col-md-3 mb-3">

              <%= image_tag image,
                    class: "img-fluid rounded shadow",
                    style: "height: 200px; width: 100%; object-fit: cover;" %>

            </div>

          <% end %>

        </div>

      <% else %>

        <p class="text-muted">
          No images uploaded for this product.
        </p>

      <% end %>

      <hr>

      <h4 class="mb-3">
        Upload More Images
      </h4>

      <%= form_with model: @product,
            url: upload_images_product_path(@product),
            method: :patch,
            local: true do |form| %>

        <div class="mb-3">

          <%= form.label :images, "Select Images", class: "form-label" %>

          <%= form.file_field :images,
                multiple: true,
                class: "form-control" %>

        </div>

        <%= form.submit "Upload Images",
              class: "btn btn-success mb-3" %>

      <% end %>

      <%= link_to "Back to Products",
            products_path,
            class: "btn btn-primary" %>

    </div>

  </div>

</div>