<div class="container py-5">

  <!-- Hero Section -->
  <div class="text-center text-white rounded-4 shadow-lg p-5 mb-5"
       style="background: linear-gradient(135deg, #4f46e5, #06b6d4);">

    <h1 class="display-4 fw-bold">
      Welcome to My Store
    </h1>

    <p class="lead mt-3">
      Discover amazing products at the best prices.
    </p>

    <% unless user_signed_in? %>

      <div class="mt-4">

        <%= link_to "Sign Up",
              new_user_registration_path,
              class: "btn btn-warning btn-lg px-4 me-3 shadow" %>

        <%= link_to "Log In",
              new_user_session_path,
              class: "btn btn-light btn-lg px-4 shadow" %>

      </div>

    <% end %>

  </div>



  <% if user_signed_in? %>

    <!-- User Card -->
    <div class="card border-0 shadow-lg rounded-4 mb-5">

      <div class="card-body p-4">

        <h3 class="text-primary">
          👋 Welcome Back!
        </h3>

        <hr>

        <p class="fs-5">
          <strong>Email:</strong>
          <span class="text-success">
            <%= current_user.email %>
          </span>
        </p>

        <div class="d-flex gap-3 mt-4">

          <%= link_to "View Products",
                products_path,
                class: "btn btn-primary btn-lg shadow" %>

          <%= button_to "Logout",
                destroy_user_session_path,
                method: :delete,
                class: "btn btn-danger btn-lg shadow" %>

        </div>

      </div>

    </div>

  <% else %>

    <!-- Guest Card -->

    <div class="alert alert-info shadow-sm rounded-4 text-center fs-5">

      Please sign in to explore all products.

    </div>

    <div class="text-center mb-5">

      <%= link_to "Browse Products",
            products_path,
            class: "btn btn-primary btn-lg px-5 shadow" %>

    </div>

  <% end %>



  <!-- Categories -->

  <div class="text-center mb-4">

    <h2 class="fw-bold text-primary">
      🛍 Store Categories
    </h2>

    <p class="text-muted">
      Browse products by category
    </p>

  </div>

  <div class="row">

    <% @categories.each do |category| %>

      <div class="col-lg-4 col-md-6 mb-4">

        <div class="card border-0 shadow rounded-4 h-100">

          <div class="card-body text-center">

            <div class="display-4 mb-3">
              📦
            </div>

            <h4 class="fw-bold">
              <%= category.name %>
            </h4>

            <p class="text-muted">
              Explore products in this category.
            </p>

            <%= link_to "View Category",
                  category_path(category),
                  class: "btn btn-outline-primary rounded-pill px-4" %>

          </div>

        </div>

      </div>

    <% end %>

  </div>



  <!-- Bottom Banner -->

  <div class="mt-5 text-center rounded-4 p-5 shadow"
       style="background: linear-gradient(135deg,#f97316,#ef4444);">

    <h2 class="text-white fw-bold">
      Start Shopping Today!
    </h2>

    <p class="text-white fs-5">
      Browse our latest collection of products.
    </p>

    <%= link_to "Shop Now",
          products_path,
          class: "btn btn-light btn-lg px-5 mt-3 shadow" %>

  </div>

</div>